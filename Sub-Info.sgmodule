[Script]
my-sub_a = type=generic,timeout=20,script-path=my_sub_info.js,argument=url="去除引号，转换后的nexi订阅地址"&name=Nexitally

my-sub_b = type=generic,timeout=20,script-path=my_sub_info.js,argument=url=“去除引号，转换后的flower订阅地址”&name=Flower

[Panel]
机场信息A = script-name=my-sub_a,title=正在加载,content=读取中...,update-interval=3600
机场信息B = script-name=my-sub_b,title=正在加载,content=读取中...,update-interval=3600
